// settings.slint — Panon 设置窗口（自定义 Fluent Design 风格）
//
// 不依赖外部样式，所有控件外观由 Theme global 控制。
// 自定义控件：CustomSlider / CustomSwitch / CustomButton / CustomComboBox

import { ScrollView } from "std-widgets.slint";

// ============== 主题配色 ==============
export global Theme {
    in property <bool> dark-mode: true;

    out property <color> window-bg:      Theme.dark-mode ? #1C1C1C : #FFFFFF;
    out property <color> card-bg:        Theme.dark-mode ? #1F1F1F : #FFFFFF;
    out property <color> text-primary:   Theme.dark-mode ? #FFFFFF : #1A1A1A;
    out property <color> text-secondary: Theme.dark-mode ? #B0B0B0 : #616161;
    out property <color> accent:         Theme.dark-mode ? #60CDFF : #005FB8;
    out property <color> accent-text:    Theme.dark-mode ? #000000 : #FFFFFF;
    out property <color> control-bg:     Theme.dark-mode ? #2C2C2C : #FFFFFF;
    out property <color> border:         Theme.dark-mode ? #3A3A3A : #E0E0E0;
    out property <color> separator:      Theme.dark-mode ? #2A2A2A : #E0E0E0;
    out property <color> hover:          Theme.dark-mode ? #333333 : #F0F0F0;
    out property <color> track-bg:       Theme.dark-mode ? #3A3A3A : #E0E0E0;
    out property <color> track-fill:     Theme.dark-mode ? #60CDFF : #005FB8;
    out property <color> select-bg:      Theme.dark-mode ? #2A4A5A : #D0E8F8;
}

// ============== 卡片容器 ==============
component Card inherits Rectangle {
    background: Theme.card-bg;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.border;

    VerticalLayout {
        padding: 18px;
        spacing: 14px;
        alignment: start;
        @children
    }
}

// ============== 分组标题 ==============
component SectionHeader inherits Rectangle {
    in property <string> title;
    height: 24px;

    HorizontalLayout {
        spacing: 10px;
        alignment: start;

        Rectangle {
            width: 4px;
            height: 18px;
            background: Theme.accent;
            border-radius: 2px;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: root.title;
            font-size: 16px;
            font-weight: 700;
            color: Theme.text-primary;
            vertical-alignment: center;
        }
    }
}

// ============== 自定义滑块（带可见轨道） ==============
component CustomSlider inherits Rectangle {
    in-out property <float> value: 0;
    in property <float> minimum: 0;
    in property <float> maximum: 100;
    in property <bool> enabled: true;
    callback changed(float);

    height: 28px;
    horizontal-stretch: 1;

    // 百分比 0..1
    property <float> pct: root.maximum > root.minimum
        ? clamp((root.value - root.minimum) / (root.maximum - root.minimum), 0, 1)
        : 0;

    // 轨道：用 HorizontalLayout 按比例分割已填充/未填充
    HorizontalLayout {
        x: 0;
        y: (parent.height - 6px) / 2;
        width: parent.width;
        height: 6px;
        spacing: 0;

        // 已填充部分
        Rectangle {
            horizontal-stretch: root.pct;
            background: root.enabled ? Theme.accent : Theme.text-secondary;
            border-top-left-radius: 3px;
            border-bottom-left-radius: 3px;
        }

        // 未填充部分
        Rectangle {
            horizontal-stretch: 1 - root.pct;
            background: Theme.track-bg;
            border-top-right-radius: 3px;
            border-bottom-right-radius: 3px;
        }
    }

    // Handle（圆点）
    Rectangle {
        y: (parent.height - self.height) / 2;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: root.enabled ? Theme.accent : Theme.text-secondary;
        border-width: 2px;
        border-color: Theme.card-bg;
        x: root.pct * (parent.width - self.width);
    }

    // 触摸区域
    TouchArea {
        enabled: root.enabled;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;

        pointer-event => {
            if self.pressed && root.maximum > root.minimum {
                let val = root.minimum + clamp(self.mouse-x / self.width, 0, 1) * (root.maximum - root.minimum);
                root.value = val;
                root.changed(val);
            }
        }
    }
}

// ============== 自定义开关 ==============
component CustomSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled();

    width: 44px;
    height: 24px;
    border-radius: 12px;

    background: !root.enabled
        ? Theme.track-bg
        : root.checked ? Theme.accent : Theme.track-bg;

    border-width: !root.enabled || root.checked ? 0px : 1px;
    border-color: Theme.border;

    animate background { duration: 150ms; }

    // Knob
    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        y: (parent.height - self.height) / 2;
        x: root.checked ? parent.width - self.width - 4px : 4px;
        background: root.enabled
            ? (root.checked ? Theme.accent-text : Theme.text-secondary)
            : Theme.text-secondary;

        animate x { duration: 150ms; }
    }

    TouchArea {
        enabled: root.enabled;
        width: parent.width;
        height: parent.height;
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }
}

// ============== 自定义按钮 ==============
component CustomButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked;

    height: 34px;
    min-width: 80px;
    border-radius: 6px;

    background: btn-touch.has-hover && root.enabled
        ? Theme.hover
        : Theme.control-bg;

    border-width: 1px;
    border-color: Theme.border;

    animate background { duration: 100ms; }

    Text {
        text: root.text;
        font-size: 13px;
        color: root.enabled ? Theme.text-primary : Theme.text-secondary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    btn-touch := TouchArea {
        enabled: root.enabled;
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

// ============== 自定义下拉框（页面内定位，滚动即收起） ==============
component CustomComboBox inherits Rectangle {
    in property <[string]> model;
    in-out property <int> current-index: 0;
    in property <bool> enabled: true;
    callback selected(int);

    height: 34px;
    border-radius: 6px;

    background: combo-touch.has-hover && root.enabled
        ? Theme.hover
        : Theme.control-bg;

    border-width: 1px;
    border-color: Theme.border;

    animate background { duration: 100ms; }

    // 当前选中项文本
    property <string> current-text: root.current-index >= 0 && root.current-index < root.model.length
        ? root.model[root.current-index]
        : "";

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 10px;

        Text {
            text: root.current-text;
            font-size: 13px;
            color: root.enabled ? Theme.text-primary : Theme.text-secondary;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }

        // 下拉箭头
        Path {
            width: 10px;
            height: 6px;
            y: (parent.height - self.height) / 2;
            fill: root.enabled ? Theme.text-secondary : Theme.border;
            commands: "M 0 0 L 10 0 L 5 6 Z";
        }
    }

    combo-touch := TouchArea {
        enabled: root.enabled;
        width: parent.width;
        height: parent.height;
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 2px;
        width: root.width;
        height: min(root.model.length * 30px, 240px);

        Rectangle {
            background: Theme.card-bg;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: 6px;
            clip: true;

            ScrollView {
                VerticalLayout {
                    spacing: 0px;

                    for item[i] in root.model : Rectangle {
                        height: 30px;
                        background: i == root.current-index
                            ? #E8E8E8
                            : (item-touch.has-hover ? Theme.hover : transparent);

                        Text {
                            text: item;
                            font-size: 13px;
                            color: #1A1A1A;
                            vertical-alignment: center;
                            x: 12px;
                        }

                        item-touch := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.current-index = i;
                                root.selected(i);
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// ============== 带标签的滑块 ==============
component SliderWithLabel inherits Rectangle {
    in property <string> label;
    in property <string> value-text;
    in-out property <float> value;
    in property <float> minimum;
    in property <float> maximum;
    in property <bool> enabled: true;
    callback changed(float);

    VerticalLayout {
        spacing: 6px;

        HorizontalLayout {
            spacing: 8px;
            Text {
                text: root.label;
                font-size: 13px;
                color: root.enabled ? Theme.text-primary : Theme.text-secondary;
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: root.value-text;
                font-size: 13px;
                color: Theme.accent;
                font-weight: 700;
            }
        }

        CustomSlider {
            value <=> root.value;
            minimum: root.minimum;
            maximum: root.maximum;
            enabled: root.enabled;
            changed(v) => { root.changed(v); }
        }
    }
}

// ============== 开关行（标题左 + 开关右） ==============
component ToggleRow inherits Rectangle {
    in property <string> title;
    in property <string> description;
    in-out property <bool> checked;
    in property <bool> enabled: true;
    callback toggled(bool);

    HorizontalLayout {
        spacing: 12px;

        VerticalLayout {
            spacing: 2px;
            horizontal-stretch: 1;
            Text {
                text: root.title;
                font-size: 14px;
                color: root.enabled ? Theme.text-primary : Theme.text-secondary;
            }
            if root.description != "" : Text {
                text: root.description;
                font-size: 12px;
                color: Theme.text-secondary;
                wrap: word-wrap;
            }
        }

        CustomSwitch {
            checked <=> root.checked;
            enabled: root.enabled;
            toggled => { root.toggled(root.checked); }
        }
    }
}

// ============== 下拉框行（标题上 + 下拉框下） ==============
component ComboRow inherits Rectangle {
    in property <string> title;
    in property <string> description;
    in property <[string]> model;
    in-out property <int> current-index;
    callback selected(int);

    VerticalLayout {
        spacing: 6px;

        Text {
            text: root.title;
            font-size: 14px;
            font-weight: 600;
            color: Theme.text-primary;
        }
        if root.description != "" : Text {
            text: root.description;
            font-size: 12px;
            color: Theme.text-secondary;
            wrap: word-wrap;
        }
        combo := CustomComboBox {
            model: root.model;
            current-index <=> root.current-index;
            selected(idx) => { root.selected(combo.current-index); }
        }
    }
}

// ============== 主窗口（对齐 C# SettingsPage.xaml 瀑布卡片布局） ==============
export component SettingsWindow inherits Window {
    title: "Panon 设置";
    icon: @image-url("../assets/Panon.png");
    preferred-width: 720px;
    preferred-height: 600px;
    min-width: 520px;
    min-height: 400px;
    background: Theme.window-bg;
    default-font-family: "Microsoft YaHei";

    // === 音频设置 ===
    in-out property <bool> reduce-bass;
    in-out property <float> bass-resolution-level;
    in-out property <float> fps;

    // === 显示设置 ===
    in-out property <int> visual-effect-idx;
    in-out property <int> gravity;
    in-out property <bool> inversion;
    in-out property <float> bar-width;
    in-out property <float> gap-width;
    in-out property <int> fill-mode;

    // === 颜色设置 ===
    in-out property <int> color-space-idx;
    in-out property <float> hsl-hue-from;
    in-out property <float> hsl-hue-to;
    in-out property <float> hsl-saturation;
    in-out property <float> hsl-lightness;
    in-out property <float> hsluv-hue-from;
    in-out property <float> hsluv-hue-to;
    in-out property <float> hsluv-saturation;
    in-out property <float> hsluv-lightness;
    in-out property <int> preset-idx;

    // === Windows 设置 ===
    in-out property <int> target-monitor-idx;
    in-out property <bool> startup;
    in-out property <bool> enable-transparency;
    in-out property <int> overlay-mode;
    in-out property <float> spectrum-max-height;
    in property <float> spectrum-max-height-max: 300;

    // === 只读数据（Rust 设置） ===
    in property <[string]> monitor-names: ["所有显示器", "主显示器"];
    in property <[string]> preset-names: ["预设"];

    // === 回调 ===
    callback save-requested();
    callback target-monitor-changed();
    callback max-height-changed();
    callback transparency-changed();
    callback startup-changed(bool);
    callback random-color-clicked();
    callback preset-selected(int);
    callback check-actions();

    // 每 200ms 检查是否有托盘退出请求
    Timer {
        interval: 200ms;
        running: true;
        triggered => { root.check-actions(); }
    }

    ScrollView {
        VerticalLayout {
            padding-left: 20px;
            padding-right: 20px;
            padding-top: 24px;
            padding-bottom: 24px;
            spacing: 12px;
            alignment: start;

            // ============================================================
            // 音频设置卡片（对齐 C# 音频卡片）
            // ============================================================
            Card {
                SectionHeader { title: "音频"; }

                ToggleRow {
                    title: "降低低音权重";
                    description: "降低低频段的视觉高度，避免低音过强时频谱被低频柱子占满。适合听感低音偏重的音乐。";
                    checked <=> root.reduce-bass;
                    toggled(c) => { root.save-requested(); }
                }

                SliderWithLabel {
                    label: "频率分辨率 (0-6)";
                    value-text: "\{round(root.bass-resolution-level)}";
                    value <=> root.bass-resolution-level;
                    minimum: 0;
                    maximum: 6;
                    changed(v) => { root.save-requested(); }
                }
                Text {
                    text: "控制 FFT 分析的频率范围。值越大仅显示更低频段，柱子波动越大；值越小覆盖更宽频段，柱子波动越小。";
                    font-size: 12px;
                    color: Theme.text-secondary;
                    wrap: word-wrap;
                }

                SliderWithLabel {
                    label: "帧率 (FPS)";
                    value-text: "\{round(root.fps)}";
                    value <=> root.fps;
                    minimum: 10;
                    maximum: 60;
                    changed(v) => { root.save-requested(); }
                }
                Text {
                    text: "每秒渲染次数。越高越流畅但越耗 CPU，建议 30-60。";
                    font-size: 12px;
                    color: Theme.text-secondary;
                    wrap: word-wrap;
                }
            }

            // ============================================================
            // 显示设置卡片（对齐 C# 显示卡片）
            // ============================================================
            Card {
                SectionHeader { title: "显示"; }

                ComboRow {
                    title: "频谱方向";
                    description: "控制频谱柱子的生长方向。方向自动根据任务栏位置适配（靠左时从左往右，靠右时从右往左）。此选项用于微调。";
                    model: ["居中 (向两侧扩展)", "靠屏幕远边（任务栏在底部时靠上）", "靠任务栏边缘 (默认)"];
                    current-index <=> root.gravity;
                    selected(idx) => { root.save-requested(); }
                }

                ToggleRow {
                    title: "反转频谱";
                    description: "开启后，安静时显示满柱，有声时柱子缩短。视觉效果与正常相反。";
                    checked <=> root.inversion;
                    toggled(c) => { root.save-requested(); }
                }

                SliderWithLabel {
                    label: "柱子宽度（仅柱状图有效）";
                    value-text: "\{round(root.bar-width)} px";
                    value <=> root.bar-width;
                    minimum: 1;
                    maximum: 30;
                    enabled: root.visual-effect-idx == 0;
                    changed(v) => { root.save-requested(); }
                }
                Text {
                    text: "仅在图形效果为「柱状图」时生效。单个柱子的像素宽度，柱子数量会自动调整填满任务栏。";
                    font-size: 12px;
                    color: Theme.text-secondary;
                    wrap: word-wrap;
                }

                SliderWithLabel {
                    label: "柱间间隙（仅柱状图有效）";
                    value-text: "\{round(root.gap-width)} px";
                    value <=> root.gap-width;
                    minimum: 0;
                    maximum: 20;
                    enabled: root.visual-effect-idx == 0;
                    changed(v) => { root.save-requested(); }
                }
                Text {
                    text: "仅在图形效果为「柱状图」时生效。相邻柱子之间的空白宽度，0=柱子紧贴。";
                    font-size: 12px;
                    color: Theme.text-secondary;
                    wrap: word-wrap;
                }

                ComboRow {
                    title: "图形效果";
                    description: "选择频谱的可视化图形效果，通过 CPU 软件渲染实现。";
                    model: ["柱状图 (bar1ch)", "波浪 (wave)", "实心单声道 (solid1ch)", "实心立体声 (solid)", "光束 (beam)", "频谱瀑布 (spectrogram)", "连线 (oie1ch)"];
                    current-index <=> root.visual-effect-idx;
                    selected(idx) => { root.save-requested(); }
                }

                ComboRow {
                    title: "填充模式";
                    description: "「铺满任务栏」频谱铺满整个任务栏后方；「仅空白区域」只在不被图标遮挡的空隙绘制柱状图（其他图形效果不受影响）。";
                    model: ["铺满任务栏", "仅空白区域 (默认)"];
                    current-index <=> root.fill-mode;
                    selected(idx) => { root.save-requested(); }
                }
            }

            // ============================================================
            // 颜色设置卡片（对齐 C# 颜色卡片）
            // ============================================================
            Card {
                SectionHeader { title: "颜色"; }

                ComboRow {
                    title: "预设配色";
                    description: "选择内置预设快速切换配色方案。调整下方滑块后会自动切换为「自定义」。";
                    model: root.preset-names;
                    current-index <=> root.preset-idx;
                    selected(idx) => {
                        if idx < root.preset-names.length - 1 {
                            root.preset-selected(idx);
                        }
                    }
                }

                // 随机颜色按钮
                Rectangle {
                    height: 50px;
                    HorizontalLayout {
                        spacing: 12px;
                        VerticalLayout {
                            spacing: 2px;
                            horizontal-stretch: 1;
                            Text {
                                text: "随机颜色";
                                font-size: 14px;
                                color: Theme.text-primary;
                            }
                            Text {
                                text: "随机生成一组配色方案（会自动切换到 HSLuv 色彩空间）。多按几次直到满意。";
                                font-size: 12px;
                                color: Theme.text-secondary;
                                wrap: word-wrap;
                            }
                        }
                        CustomButton {
                            text: "随机";
                            clicked => { root.random-color-clicked(); }
                        }
                    }
                }

                ComboRow {
                    title: "色彩空间";
                    description: "HSL 是传统色彩模型，高饱和度时颜色鲜艳；HSLuv 是感知均匀色彩空间，亮度变化更自然。切换后下方滑块值会自动更新。";
                    model: ["HSL (标准，饱和度对比较强)", "HSLuv (感知均匀，颜色更柔和)"];
                    current-index <=> root.color-space-idx;
                    selected(idx) => { root.save-requested(); }
                }

                // HSL 滑块
                if root.color-space-idx == 0 : VerticalLayout {
                    spacing: 12px;
                    SliderWithLabel {
                        label: "色相起始值";
                        value-text: "\{round(root.hsl-hue-from)}";
                        value <=> root.hsl-hue-from;
                        minimum: -4000;
                        maximum: 4000;
                        changed(v) => { root.preset-idx = root.preset-names.length - 1; root.save-requested(); }
                    }
                    Text {
                        text: "频谱最左侧柱子的色相基准值。0=红，120=绿，240=蓝，可超出 360 实现循环渐变。";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                    SliderWithLabel {
                        label: "色相结束值";
                        value-text: "\{round(root.hsl-hue-to)}";
                        value <=> root.hsl-hue-to;
                        minimum: -4000;
                        maximum: 4000;
                        changed(v) => { root.preset-idx = root.preset-names.length - 1; root.save-requested(); }
                    }
                    Text {
                        text: "频谱最右侧柱子的色相基准值。与起始值的差决定渐变范围，负值可反向渐变。";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                    SliderWithLabel {
                        label: "饱和度";
                        value-text: "\{round(root.hsl-saturation)}";
                        value <=> root.hsl-saturation;
                        minimum: 0;
                        maximum: 100;
                        changed(v) => { root.preset-idx = root.preset-names.length - 1; root.save-requested(); }
                    }
                    Text {
                        text: "颜色鲜艳程度。0=灰色，100=最鲜艳。建议 60-100。";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                    SliderWithLabel {
                        label: "亮度";
                        value-text: "\{round(root.hsl-lightness)}";
                        value <=> root.hsl-lightness;
                        minimum: 0;
                        maximum: 100;
                        changed(v) => { root.preset-idx = root.preset-names.length - 1; root.save-requested(); }
                    }
                    Text {
                        text: "颜色明暗。0=黑色，50=正常，100=白色。建议 40-70，过高会发白。";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                }

                // HSLuv 滑块
                if root.color-space-idx == 1 : VerticalLayout {
                    spacing: 12px;
                    SliderWithLabel {
                        label: "色相起始值";
                        value-text: "\{round(root.hsluv-hue-from)}";
                        value <=> root.hsluv-hue-from;
                        minimum: -4000;
                        maximum: 4000;
                        changed(v) => { root.preset-idx = root.preset-names.length - 1; root.save-requested(); }
                    }
                    Text {
                        text: "频谱最左侧柱子的色相基准值。0=红，120=绿，240=蓝，可超出 360 实现循环渐变。";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                    SliderWithLabel {
                        label: "色相结束值";
                        value-text: "\{round(root.hsluv-hue-to)}";
                        value <=> root.hsluv-hue-to;
                        minimum: -4000;
                        maximum: 4000;
                        changed(v) => { root.preset-idx = root.preset-names.length - 1; root.save-requested(); }
                    }
                    Text {
                        text: "频谱最右侧柱子的色相基准值。与起始值的差决定渐变范围，负值可反向渐变。";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                    SliderWithLabel {
                        label: "饱和度";
                        value-text: "\{round(root.hsluv-saturation)}";
                        value <=> root.hsluv-saturation;
                        minimum: 0;
                        maximum: 100;
                        changed(v) => { root.preset-idx = root.preset-names.length - 1; root.save-requested(); }
                    }
                    Text {
                        text: "颜色鲜艳程度。0=灰色，100=最鲜艳。建议 60-100。";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                    SliderWithLabel {
                        label: "亮度";
                        value-text: "\{round(root.hsluv-lightness)}";
                        value <=> root.hsluv-lightness;
                        minimum: 0;
                        maximum: 100;
                        changed(v) => { root.preset-idx = root.preset-names.length - 1; root.save-requested(); }
                    }
                    Text {
                        text: "颜色明暗。0=黑色，50=正常，100=白色。建议 40-70，过高会发白。";
                        font-size: 12px;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }

            // ============================================================
            // Windows 设置卡片（对齐 C# Windows 设置卡片）
            // ============================================================
            Card {
                SectionHeader { title: "Windows 设置"; }

                ComboRow {
                    title: "覆盖模式";
                    description: "「任务栏覆盖在频谱上面」频谱被任务栏遮挡，柱子上半部分可见；「频谱覆盖在任务栏上面」频谱显示在任务栏和图标前方，透明区域鼠标可穿透。";
                    model: ["任务栏覆盖在频谱上面 (默认)", "频谱覆盖在任务栏上面"];
                    current-index <=> root.overlay-mode;
                    selected(idx) => { root.save-requested(); }
                }

                SliderWithLabel {
                    label: "频谱窗口高度";
                    value-text: root.spectrum-max-height == 0 ? "自动" : "\{round(root.spectrum-max-height)} px";
                    value <=> root.spectrum-max-height;
                    minimum: 0;
                    maximum: root.spectrum-max-height-max;
                    changed(v) => {
                        root.save-requested();
                        root.max-height-changed();
                    }
                }
                Text {
                    text: "0=自动（跟随任务栏高度，默认）；>0=限制频谱高度为该值（不超过任务栏高度），底部对齐任务栏。适用某些电脑任务栏偏高导致频谱效果不好的情况。";
                    font-size: 12px;
                    color: Theme.text-secondary;
                    wrap: word-wrap;
                }

                ComboRow {
                    title: "目标显示器";
                    description: "选择在哪台显示器的任务栏上显示频谱。默认为主显示器；选择「所有显示器」则每台显示器各自显示（共享同一套颜色和参数）。";
                    model: root.monitor-names;
                    current-index <=> root.target-monitor-idx;
                    selected(idx) => { root.target-monitor-changed(); }
                }

                ToggleRow {
                    title: "开机自启";
                    description: "开启后，程序会在系统启动时自动运行。开启/关闭会修改注册表 HKCU\\...\\Run 中的启动项。";
                    checked <=> root.startup;
                    toggled(c) => { root.startup-changed(c); }
                }

                ToggleRow {
                    title: "系统透明效果";
                    description: "开启 Windows 透明效果（同时修改注册表 EnableTransparency 和 UseOLEDTaskbarTransparency 键）。";
                    checked <=> root.enable-transparency;
                    toggled(c) => { root.transparency-changed(); }
                }
            }

            // 底部间距
            Rectangle { height: 8px; }
        }
    }
}
