<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Panon.Windows.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- 卡片样式：圆角 + 主题背景 + 细边框 -->
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,14" />
        </Style>

        <!-- 分组标题样式 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        </Style>

        <!-- 分组标题图标 -->
        <Style x:Key="SectionIcon" TargetType="FontIcon">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
        </Style>

        <!-- 说明文字样式：灰色小字 -->
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <!-- 当前值显示样式 -->
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- 单个设置项容器：统一上下间距 -->
        <Style x:Key="SettingItem" TargetType="StackPanel">
            <Setter Property="Spacing" Value="2" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,20" Spacing="12" MaxWidth="720" HorizontalAlignment="Stretch">

            <!-- === 音频设置卡片 === -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE9E9;" Style="{StaticResource SectionIcon}" />
                        <TextBlock Text="音频" Style="{StaticResource SectionTitle}" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ToggleSwitch x:Name="ReduceBassToggle" Header="降低低音权重"
                                      OnContent="开启" OffContent="关闭"
                                      Toggled="OnSettingChanged" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="降低低频段的视觉高度，避免低音过强时频谱被低频柱子占满。适合听感低音偏重的音乐。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Slider x:Name="BassResolutionSlider" Header="频率分辨率 (0-6)"
                                StepFrequency="1" TickFrequency="1" TickPlacement="Outside"
                                ValueChanged="OnSliderChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HintText}" Text="控制 FFT 分析的频率范围。值越大仅显示更低频段，柱子波动越大；值越小覆盖更宽频段，柱子波动越小。" />
                            <TextBlock Grid.Column="1" x:Name="BassResolutionValue" Style="{StaticResource ValueText}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Slider x:Name="FpsSlider" Header="帧率 (FPS)"
                                StepFrequency="5" TickFrequency="10" TickPlacement="Outside"
                                ValueChanged="OnSliderChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HintText}" Text="每秒渲染次数。越高越流畅但越耗 CPU，建议 30-60。" />
                            <TextBlock Grid.Column="1" x:Name="FpsValue" Style="{StaticResource ValueText}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- === 显示设置卡片 === -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7F4;" Style="{StaticResource SectionIcon}" />
                        <TextBlock Text="显示" Style="{StaticResource SectionTitle}" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ComboBox x:Name="GravityCombo" Header="频谱方向"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnSettingChanged">
                            <ComboBoxItem Content="居中 (从任务栏中线向上下扩展)" Tag="0" />
                            <ComboBoxItem Content="靠任务栏上边缘向下" Tag="1" />
                            <ComboBoxItem Content="靠任务栏下边缘向上 (默认)" Tag="2" />
                            <ComboBoxItem Content="从右到左 (横向)" Tag="3" />
                            <ComboBoxItem Content="从左到右 (横向)" Tag="4" />
                        </ComboBox>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="控制频谱柱子的生长方向。任务栏在屏幕底部时默认靠下边缘向上。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ToggleSwitch x:Name="InversionToggle" Header="反转频谱"
                                      OnContent="开启" OffContent="关闭"
                                      Toggled="OnSettingChanged" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="开启后，安静时显示满柱，有声时柱子缩短。视觉效果与正常相反。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Slider x:Name="BarWidthSlider" Header="柱子宽度（仅柱状图有效）"
                                StepFrequency="1" TickFrequency="2" TickPlacement="Outside"
                                ValueChanged="OnBarWidthChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HintText}" Text="仅在图形效果为「柱状图」时生效。单个柱子的像素宽度，柱子数量会自动调整填满任务栏。" />
                            <TextBlock Grid.Column="1" x:Name="BarWidthValue" Style="{StaticResource ValueText}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Slider x:Name="GapWidthSlider" Header="柱间间隙（仅柱状图有效）"
                                StepFrequency="1" TickFrequency="2" TickPlacement="Outside"
                                ValueChanged="OnGapWidthChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HintText}" Text="仅在图形效果为「柱状图」时生效。相邻柱子之间的空白宽度，0=柱子紧贴。" />
                            <TextBlock Grid.Column="1" x:Name="GapWidthValue" Style="{StaticResource ValueText}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ComboBox x:Name="VisualEffectCombo" Header="图形效果"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnSettingChanged">
                            <ComboBoxItem Content="柱状图 (bar1ch)" Tag="bar1ch" />
                            <ComboBoxItem Content="波浪 (wave)" Tag="wave" />
                            <ComboBoxItem Content="实心单声道 (solid1ch)" Tag="solid1ch" />
                            <ComboBoxItem Content="实心立体声 (solid)" Tag="solid" />
                            <ComboBoxItem Content="光束 (beam)" Tag="beam" />
                            <ComboBoxItem Content="频谱瀑布 (spectrogram)" Tag="spectrogram" />
                            <ComboBoxItem Content="连线 (oie1ch)" Tag="oie1ch" />
                        </ComboBox>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="选择频谱的可视化图形效果，通过 CPU 软件渲染实现。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ComboBox x:Name="FillModeCombo" Header="填充模式"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnSettingChanged">
                            <ComboBoxItem Content="铺满任务栏" Tag="0" />
                            <ComboBoxItem Content="仅空白区域 (默认)" Tag="1" />
                        </ComboBox>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="「铺满任务栏」频谱铺满整个任务栏后方；「仅空白区域」只在不被图标遮挡的空隙绘制柱状图（其他图形效果不受影响）。" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- === 颜色设置卡片 === -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE790;" Style="{StaticResource SectionIcon}" />
                        <TextBlock Text="颜色" Style="{StaticResource SectionTitle}" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ComboBox x:Name="ColorPresetCombo" Header="预设配色"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnColorPresetChanged">
                            <ComboBoxItem Content="彩虹 (默认渐变)" Tag="0" />
                            <ComboBoxItem Content="霓虹 (紫青渐变)" Tag="1" />
                            <ComboBoxItem Content="极光 (绿蓝渐变)" Tag="2" />
                            <ComboBoxItem Content="日落 (红橙渐变)" Tag="3" />
                            <ComboBoxItem Content="海洋 (蓝青渐变)" Tag="4" />
                            <ComboBoxItem Content="火焰 (红黄渐变)" Tag="5" />
                            <ComboBoxItem Content="森林 (绿黄渐变)" Tag="6" />
                            <ComboBoxItem Content="紫罗兰 (紫粉渐变)" Tag="7" />
                            <ComboBoxItem Content="自定义 (当前配置)" Tag="-1" />
                        </ComboBox>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="选择内置预设快速切换配色方案。调整下方滑块后会自动切换为&quot;自定义&quot;。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Button x:Name="RandomColorButton" Content="随机颜色"
                                Click="OnRandomColorClick" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="随机生成一组配色方案（会自动切换到 HSLuv 色彩空间）。多按几次直到满意。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <RadioButtons x:Name="ColorSpaceRadio" Header="色彩空间"
                                      SelectionChanged="OnColorSpaceChanged">
                            <RadioButton Content="HSL (标准，饱和度对比较强)" Tag="HSL" />
                            <RadioButton Content="HSLuv (感知均匀，颜色更柔和)" Tag="HSLuv" />
                        </RadioButtons>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="HSL 是传统色彩模型，高饱和度时颜色鲜艳；HSLuv 是感知均匀色彩空间，亮度变化更自然。切换后下方滑块值会自动更新。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Slider x:Name="HueFromSlider" Header="色相起始值"
                                StepFrequency="10"
                                ValueChanged="OnColorSliderChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HintText}" Text="频谱最左侧柱子的色相基准值。0=红，120=绿，240=蓝，可超出 360 实现循环渐变。" />
                            <TextBlock Grid.Column="1" x:Name="HueFromValue" Style="{StaticResource ValueText}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Slider x:Name="HueToSlider" Header="色相结束值"
                                StepFrequency="10"
                                ValueChanged="OnColorSliderChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HintText}" Text="频谱最右侧柱子的色相基准值。与起始值的差决定渐变范围，负值可反向渐变。" />
                            <TextBlock Grid.Column="1" x:Name="HueToValue" Style="{StaticResource ValueText}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Slider x:Name="SaturationSlider" Header="饱和度"
                                StepFrequency="5"
                                ValueChanged="OnColorSliderChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HintText}" Text="颜色鲜艳程度。0=灰色，100=最鲜艳。建议 60-100。" />
                            <TextBlock Grid.Column="1" x:Name="SaturationValue" Style="{StaticResource ValueText}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <Slider x:Name="LightnessSlider" Header="亮度"
                                StepFrequency="5"
                                ValueChanged="OnColorSliderChanged" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource HintText}" Text="颜色明暗。0=黑色，50=正常，100=白色。建议 40-70，过高会发白。" />
                            <TextBlock Grid.Column="1" x:Name="LightnessValue" Style="{StaticResource ValueText}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- === Windows 专属设置卡片 === -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE783;" Style="{StaticResource SectionIcon}" />
                        <TextBlock Text="Windows 设置" Style="{StaticResource SectionTitle}" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ComboBox x:Name="OverlayModeCombo" Header="覆盖模式"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnSettingChanged">
                            <ComboBoxItem Content="任务栏覆盖在频谱上面 (默认)" Tag="1" />
                            <ComboBoxItem Content="频谱覆盖在任务栏上面" Tag="2" />
                        </ComboBox>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="「任务栏覆盖在频谱上面」频谱被任务栏遮挡，柱子上半部分可见；「频谱覆盖在任务栏上面」频谱显示在任务栏和图标前方，透明区域鼠标可穿透。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ComboBox x:Name="TargetMonitorCombo" Header="目标显示器"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnSettingChanged">
                            <!-- 运行时动态填充：主显示器 / 显示器2 / ... / 所有显示器 -->
                        </ComboBox>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="选择在哪台显示器的任务栏上显示频谱。默认为主显示器；选择「所有显示器」则每台显示器各自显示（共享同一套颜色和参数）。" />
                    </StackPanel>

                    <StackPanel Style="{StaticResource SettingItem}">
                        <ToggleSwitch x:Name="StartWithWindowsToggle" Header="开机自启"
                                      OnContent="开启" OffContent="关闭"
                                      Toggled="OnSettingChanged" />
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="开启后，程序会在系统启动时自动运行。开启/关闭会修改注册表 HKCU\...\Run 中的启动项。" />
                    </StackPanel>

                    <!-- 系统透明效果 -->
                    <StackPanel Style="{StaticResource SettingItem}">
                        <ToggleSwitch x:Name="TransparencyToggle" Header="系统透明效果"
                                      OnContent="开启" OffContent="关闭"
                                      Toggled="OnTransparencyToggled" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="TransparencyHintText" Style="{StaticResource HintText}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 底部间距 -->
            <Border Height="8" />

        </StackPanel>
    </ScrollViewer>
</Page>
